{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "corepack enable && pnpm install --frozen-lockfile=false",
  "buildCommand": "pnpm --filter @workspace/dhuruv-portfolio run build:vercel",
  "outputDirectory": "artifacts/dhuruv-portfolio/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
